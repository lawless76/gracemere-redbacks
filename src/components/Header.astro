---
const navLinks = [
  { href: '/',          label: 'Home'     },
  { href: '/about',     label: 'About'    },
  { href: '/programs',  label: 'Programs' },
  { href: '/news',      label: 'News'     },
  { href: '/contact',   label: 'Contact'  },
];
const currentPath = Astro.url.pathname;
---
<header class="site-header">
  <div class="header-inner">

    <a href="/" class="site-logo" aria-label="Gracemere Redbacks Home">
      <!-- Replace this with your actual logo once you have it -->
      <div class="logo-placeholder" aria-hidden="true">⚽</div>
      <div class="logo-text">
        <span class="club-name">Gracemere Redbacks</span>
        <span class="club-tagline">Soccer Club</span>
      </div>
    </a>

    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <nav class="primary-nav" aria-label="Primary navigation">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={
                link.href === '/'
                  ? currentPath === '/' ? 'page' : undefined
                  : currentPath.startsWith(link.href) ? 'page' : undefined
              }
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </div>
</header>
