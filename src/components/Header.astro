---
const navLinks = [
  { href: '/',          label: 'Home'     },
  { href: '/about',     label: 'About'    },
  { href: '/programs',  label: 'Programs' },
  { href: '/news',      label: 'News'     },
  { href: '/contact',   label: 'Contact'  },
];
const currentPath = Astro.url.pathname;
---
<header class="site-header">
  <div class="header-inner">

    <a href="/" class="site-logo" aria-label="Gracemere Redbacks Home">
      <img src="/gracemere-redbacks-logo-banner.png" alt="Gracemere Redbacks Football Club" />
    </a>

    <nav class="primary-nav" aria-label="Primary navigation">
      <ul>
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              aria-current={
                link.href === '/'
                  ? currentPath === '/' ? 'page' : undefined
                  : currentPath.startsWith(link.href) ? 'page' : undefined
              }
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <div class="header-social">
        <a href="https://www.facebook.com/gracemereredbacksfootballclub" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/gracemereredbacksfootballclub" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

  </div>
</header>
