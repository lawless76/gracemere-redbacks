---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-grid">

    <div class="footer-brand">
      <div class="site-logo" style="margin-bottom:0.5rem">
        <div class="logo-placeholder" aria-hidden="true" style="width:40px;height:40px;font-size:1.1rem">⚽</div>
        <div class="logo-text">
          <span class="club-name" style="font-size:1.1rem">Gracemere Redbacks</span>
          <span class="club-tagline">Soccer Club</span>
        </div>
      </div>
      <p>A proud community soccer club based in Gracemere, QLD. Open to all ages and skill levels — come join the family!</p>
    </div>

    <div class="footer-col">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/programs">Programs</a></li>
        <li><a href="/news">News</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Get Involved</h4>
      <ul>
        <li><a href="/programs">Register Now</a></li>
        <li><a href="/programs">Junior Development</a></li>
        <li><a href="/programs">Volunteer</a></li>
        <li><a href="/contact">Contact Us</a></li>
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <p>&copy; {year} Gracemere Redbacks Soccer Club. All rights reserved.</p>
  </div>
</footer>
