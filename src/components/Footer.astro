---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-grid">

    <div class="footer-brand">
      <div class="site-logo" style="margin-bottom:0.5rem">
        <div class="logo-placeholder" aria-hidden="true" style="width:40px;height:40px;font-size:1.1rem">⚽</div>
        <div class="logo-text">
          <span class="club-name" style="font-size:1.1rem">Gracemere Redbacks</span>
          <span class="club-tagline">Soccer Club</span>
        </div>
      </div>
      <p>A proud community soccer club based in Gracemere, QLD. Open to all ages and skill levels — come join the family!</p>
      <div class="footer-social">
        <a href="https://www.facebook.com/gracemere.redbacks" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/gracemere.redbacks" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/programs">Programs</a></li>
        <li><a href="/news">News</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Get Involved</h4>
      <ul>
        <li><a href="/programs">Register Now</a></li>
        <li><a href="/programs">Junior Development</a></li>
        <li><a href="/programs">Volunteer</a></li>
        <li><a href="/contact">Contact Us</a></li>
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <p>&copy; {year} Gracemere Redbacks Soccer Club. All rights reserved.</p>
  </div>
</footer>
