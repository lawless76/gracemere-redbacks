---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Generate a static page for every news post
export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout
  title={post.data.title}
  description={post.data.excerpt ?? `${post.data.title} — Gracemere Redbacks`}
>

  <section class="page-hero">
    <div class="container">
      <h1>{post.data.title}</h1>
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> <span>/</span>
        <a href="/news">News</a> <span>/</span>
        <span>{post.data.title}</span>
      </nav>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px">

      <p style="margin-bottom:2rem;color:var(--color-text-muted)">
        <span class="category-tag">{post.data.category}</span>
        {formatDate(post.data.date)}
      </p>

      {post.data.image && (
        <img src={post.data.image} alt={post.data.title}
          style="width:100%;border-radius:var(--radius);margin-bottom:2rem" loading="eager" />
      )}

      <div class="prose">
        <Content />
      </div>

      <div style="margin-top:3rem;padding-top:2rem;border-top:2px solid var(--color-gray)">
        <a href="/news" style="color:var(--color-primary);font-weight:600">← Back to News</a>
      </div>

    </div>
  </section>

</BaseLayout>
